{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Hermes",
  "version": "0.0.1",
  "identifier": "com.pepsienjoyer.hermes",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Hermes",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "copyright": "",
    "shortDescription": "Convert DOCX files to HTML",
    "longDescription": "A desktop application for converting Microsoft Word DOCX files to HTML with full formatting preservation"
  }
}
